# PromptShield Configuration
# All environment variables are prefixed with PROMPTSHIELD_

PROMPTSHIELD_ENV=development
PROMPTSHIELD_LOG_LEVEL=info
PROMPTSHIELD_AUDIT_ENABLED=true
PROMPTSHIELD_MAX_INPUT_LENGTH=10000
PROMPTSHIELD_SEVERITY_THRESHOLD=0.5
PROMPTSHIELD_UNICODE_NORMALIZATION=true

# Optional: API key for authenticated access
# PROMPTSHIELD_API_KEY=your-secret-api-key-here
